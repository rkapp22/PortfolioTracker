# =============================================================================
# Copy this file to .env  ->  `cp .env.example .env`
# .env is gitignored and never committed. These dev values are fine because
# the database only listens on YOUR machine (localhost).
# =============================================================================

# --- PostgreSQL credentials --------------------------------------------------
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DB=portfolio

# Port published on the HOST. DBeaver / Power BI connect to localhost:<this>.
# Change it (e.g. to 5433) if you already run Postgres locally on 5432.
DB_HOST_PORT=5432

# --- Pipeline configuration --------------------------------------------------
# Path INSIDE the container. ./data on the host is mounted to /data.
# The committed sample lives at ./data/sample_portfolio.xlsx
EXCEL_PATH=/data/sample_portfolio.xlsx

# Reporting / base currency for all _eur conversions
BASE_CURRENCY=EUR

# --- Scheduler ---------------------------------------------------------------
# manual = container idles, you trigger runs by hand (default, recommended)
# cron   = container runs the schedule in ./crontab automatically
RUN_MODE=manual
