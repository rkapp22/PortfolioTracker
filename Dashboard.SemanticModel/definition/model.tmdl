model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: et-EE
	maxParallelismPerRefresh: 1
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["dim_date","dim_security","fact_daily_prices","fact_dividends","fact_fx_rates","fact_holdings","fact_transactions"]

annotation PBI_ProTooling = ["DevMode"]

ref table dim_date
ref table dim_security
ref table fact_daily_prices
ref table fact_dividends
ref table fact_fx_rates
ref table fact_holdings
ref table fact_transactions

ref cultureInfo en-US

